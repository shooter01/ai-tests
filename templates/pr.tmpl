{{ define "pr.tmpl" }}
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <title>PR #{{ .PR.ID }} - {{ .PR.Title }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 1100px;
      margin: 0 auto;
      padding: 24px;
      background: #f7f7f8;
      color: #222;
    }
    .card {
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 16px;
    }
    button {
      background: #1f6feb;
      color: white;
      border: 0;
      padding: 10px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }
    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    pre {
      white-space: pre-wrap;
      word-break: break-word;
      background: #0d1117;
      color: #c9d1d9;
      padding: 12px;
      border-radius: 8px;
      overflow: auto;
    }
    .muted {
      color: #666;
    }
    .status {
      font-weight: bold;
      margin-top: 12px;
    }
    .finding {
      border-left: 4px solid #ccc;
      padding-left: 12px;
      margin-bottom: 12px;
    }
    .sev-high { border-color: #d73a49; }
    .sev-medium { border-color: #d29922; }
    .sev-low { border-color: #1f883d; }
    .pill {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      background: #eee;
      font-size: 12px;
      margin-right: 6px;
    }
    .grid {
      display: grid;
      gap: 12px;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>PR #{{ .PR.ID }} — {{ .PR.Title }}</h1>
    <p>{{ .PR.Description }}</p>
    <p class="muted">
      Repo: <strong>{{ .PR.Repo }}</strong><br />
      Base: <strong>{{ .PR.BaseBranch }}</strong> → Head: <strong>{{ .PR.HeadBranch }}</strong>
    </p>

    <button id="run-review-btn" data-pr-id="{{ .PR.ID }}">Run AI Review</button>
    <div class="status">Status: <span id="review-status">idle</span></div>
    <div class="muted" id="job-id"></div>
  </div>

  <div class="card">
    <h2>Changed files</h2>
    <div class="grid">
      {{ range .PR.Files }}
      <details>
        <summary><strong>{{ .Path }}</strong></summary>
        <pre>{{ .Patch }}</pre>
      </details>
      {{ end }}
    </div>
  </div>

  <div class="card">
    <h2>AI Review Result</h2>
    <div id="review-result" class="muted">Пока пусто.</div>
  </div>

  <script src="/static/app.js"></script>
</body>
</html>
{{ end }}